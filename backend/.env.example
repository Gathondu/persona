# --- LLM (required: at least one path) ---
# Primary streaming + placeholder (omit to use OpenRouter only)
CEREBRAS_API_KEY=
CEREBRAS_MODEL=gpt-oss-120b

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-5.4-nano
APP_URL=http://localhost:5173

# --- Memory backend ---
# Local dev: sqlite (default). AWS Lambda: dynamodb via Terraform env.
MEMORY_BACKEND=sqlite

# DynamoDB (set automatically when deploying with Terraform; for local testing against AWS:)
# AWS_REGION=us-east-1
# DYNAMODB_MESSAGES_TABLE=persona-dev-messages
# DYNAMODB_PROFILE_TABLE=persona-dev-profile-memories

# --- Local FastAPI + bundled static (default dev) ---
SERVE_STATIC=true

# --- Split deploy (S3 + API Gateway): set on Lambda only ---
# SERVE_STATIC=false
# CORS_ORIGINS=https://d111111abcdef8.cloudfront.net
