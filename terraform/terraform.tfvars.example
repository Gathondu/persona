# Copy to terraform.tfvars (gitignored) and adjust:
#   copy terraform.tfvars.example terraform.tfvars
# Or pass values via: terraform apply -var="key=value" and/or TF_VAR_* env vars.

# --- Required-ish (no defaults in all cases) ---
project_name = "persona"
environment  = "dev" # dev | test | prod
aws_region     = "us-east-1"

# --- Lambda package (default matches repo layout after package_lambda.py) ---
# lambda_zip_path = "../backend/lambda-deployment.zip"

# --- Lambda sizing ---
# lambda_timeout       = 120
# lambda_memory_size   = 512

# --- API Gateway throttling ---
# api_throttle_burst_limit = 100
# api_throttle_rate_limit  = 50

# --- Optional: use an existing IAM role instead of Terraform-created role ---
# lambda_execution_role_arn = "arn:aws:iam::123456789012:role/your-lambda-role"
# attach_dynamodb_policy_to_existing_role = true # set false if the role already has DynamoDB access

# --- Optional: use existing DynamoDB / S3 (leave unset to create and manage them) ---
# Existing tables must match this stack's schema (keys, attributes, GSI BySourceSession on profile table) or the API will fail at runtime.
# existing_dynamodb_messages_table_name         = "my-project-dev-messages"
# existing_dynamodb_profile_memories_table_name = "my-project-dev-profile-memories"
# Terraform still manages the bucket policy (CloudFront OAC) and public access block when using an existing bucket.
# existing_frontend_s3_bucket_name              = "my-project-dev-frontend-123456789012"

# --- Recovery: tables/bucket/IAM already exist (e.g. partial apply or empty state) ---
# Standard names match main.tf: {project}-{env}-messages, {project}-{env}-profile-memories,
# {project}-{env}-frontend-{account_id}, role {project}-{env}-lambda.
# Example for project_name=persona, environment=prod, account 488255002567:
# existing_dynamodb_messages_table_name         = "persona-prod-messages"
# existing_dynamodb_profile_memories_table_name = "persona-prod-profile-memories"
# existing_frontend_s3_bucket_name              = "persona-prod-frontend-488255002567"
# lambda_execution_role_arn                     = "arn:aws:iam::488255002567:role/persona-prod-lambda"
# GitHub Actions: enable workflow input "Reuse existing AWS resources" to set TF_VAR_* above and run
# terraform import for resources that only have AWS IDs (Lambda, API Gateway, CloudFront, OAC). See deploy.yml.
#
# Two patterns (aligned in main.tf locals: name_prefix = project_name-environment):
#   1) Optional TF_VAR existing_* — skip Create; use data sources (DynamoDB x2, S3 bucket, IAM role via ARN).
#   2) terraform import — adopt existing managed resources (same names as locals) into state before apply.
#
# Manual import examples (replace persona-prod with your name_prefix):
#   terraform import aws_lambda_function.api persona-prod-api
#   terraform import aws_cloudfront_origin_access_control.frontend <OAC_ID>
#   terraform import aws_apigatewayv2_api.main <api-id>
#   terraform import 'aws_apigatewayv2_stage.default' '<api-id>/$default'
#   terraform import aws_apigatewayv2_integration.lambda <api-id>/<integration-id>
#   terraform import aws_apigatewayv2_route.proxy <api-id>/<route-id>
#   terraform import aws_lambda_permission.apigw persona-prod-api/AllowAPIGatewayInvoke
#   terraform import aws_cloudfront_distribution.frontend <E... distribution id>
# OAC id: aws cloudfront list-origin-access-controls --output json | jq -r '.OriginAccessControlList.Items[] | select(.Name=="persona-prod-frontend-s3-oac") | .Id'

# --- LLM keys (sensitive; prefer TF_VAR_* in CI or a local untracked tfvars file) ---
# cerebras_api_key   = ""
# openrouter_api_key = ""

# openrouter_base_url = "https://openrouter.ai/api/v1"
# app_url             = "https://your-cloudfront-or-api-url.example"
